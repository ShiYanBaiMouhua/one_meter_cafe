rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /** 管理页直接读列表；写入仅允许服务端（Cloud Functions Admin SDK） */
    match /guestNumberLogs/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
