rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * 顾客前台：浏览器创建一条记录（号码 + 服务端时间戳）。
     * 管理页：读取列表；客户端删除单条（与 read 同为公开，生产环境建议加鉴权）。
     */
    match /guestNumberLogs/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(["number", "createdAt"])
        && request.resource.data.number is string
        && request.resource.data.number.matches("^[0-9]{3}$");
      allow delete: if true;
      allow update: if false;
    }

    /**
     * 管理端首页警告条（顾客端写入，管理员读取/关闭）
     */
    match /adminMeta/{docId} {
      allow read: if true;
      allow create, update: if docId == "duplicateBanner"
        && request.resource.data.visible is bool
        && (!("message" in request.resource.data)
          || (request.resource.data.message is string
            && request.resource.data.message.size() <= 500));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
